# Database Configuration
MONGO_URI=mongodb://localhost:27017/eduflix

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
